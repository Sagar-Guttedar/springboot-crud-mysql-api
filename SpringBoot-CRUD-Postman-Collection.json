      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"department\": \"Engineering\",\n  \"salary\": 75000.00,\n  \"phone\": \"+91-9876543210\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/employees",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "employees"]
        },
        "description": "Create a new employee"
      }
    },
    {
